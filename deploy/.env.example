# ============================================
# 环境变量配置文件示例
#
# 使用方法:
# 1. 复制此文件为 .env:  cp .env.example .env
# 2. 填写实际的 API 密钥
# 3. docker-compose 会自动加载 .env 文件
# ============================================

# ========================================
# 方案一：DeepSeek（推荐，国内直连）
# ========================================
# 注册地址: https://platform.deepseek.com
# 新用户送 500 万 token 免费额度
OPENAI_API_KEY=sk-你的DeepSeek密钥
OPENAI_BASE_URL=https://api.deepseek.com/v1
PRIMARY_MODEL=deepseek-chat
FALLBACK_MODEL=deepseek-chat

# ========================================
# 方案二：智谱 GLM（国内直连）
# ========================================
# 注册地址: https://open.bigmodel.cn
# OPENAI_API_KEY=你的智谱密钥
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# PRIMARY_MODEL=glm-4-flash
# FALLBACK_MODEL=glm-4-flash

# ========================================
# 方案三：OpenAI（需要 VPN）
# ========================================
# OPENAI_API_KEY=sk-你的OpenAI密钥
# OPENAI_BASE_URL=https://api.openai.com/v1
# PRIMARY_MODEL=gpt-4-turbo
# FALLBACK_MODEL=gpt-3.5-turbo

# ========================================
# Embedding / 向量化 配置
# ========================================
# local    = 本地 HuggingFace 模型，免费、无需网络（默认）
# openai   = OpenAI 兼容 API，需要 KEY 和网络
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 如果 EMBEDDING_PROVIDER=openai，则需配置：
# EMBEDDING_MODEL=text-embedding-ada-002
# 智谱用户可设为: EMBEDDING_MODEL=embedding-2

# ========================================
# 其他可选配置
# ========================================
DEBUG=false
LOG_LEVEL=INFO
